diff --git a/.github/workflows/on-pull.yml b/.github/workflows/on-pull.yml
index 62d507a..a4eb789 100644
--- a/.github/workflows/on-pull.yml
+++ b/.github/workflows/on-pull.yml
@@ -53,6 +53,22 @@ jobs:
           node-version: 20
           cache: 'npm'
 
+      - name: Cache Build Artifacts
+        uses: actions/cache@v5
+        with:
+          path: |
+            .build-manifest.json
+            dist/
+          key: build-${{ runner.os }}-${{ hashFiles('data/schools.csv') }}
+          restore-keys: |
+            build-${{ runner.os }}-
+
+      - name: Install Dependencies
+        run: npm ci --ignore-scripts
+
+      - name: Build (incremental with cache)
+        run: npm run build:incremental
+
       - name: Configure Git
         run: |
           git config --global user.name "${{ github.actor }}"
diff --git a/.github/workflows/on-push.yml b/.github/workflows/on-push.yml
